sequenceDiagram
    participant P as Principal
    participant SA as Super Admin
    participant API as Express API
    participant DB as MongoDB
    participant S as Student
    participant C as Committee Admin

    rect rgb(220, 240, 255)
        Note over P,DB: Phase 1 — Institution Onboarding
        P->>API: POST /api/auth/register (role: admin, college: "ABC Univ")
        API->>DB: Organization.create({ name, slug, isVerified: false })
        DB-->>API: Organization created (pending)
        API-->>P: Account created, awaiting approval

        SA->>DB: Organization.findByIdAndUpdate({ isVerified: true })
        DB-->>SA: Institution approved

        P->>API: POST /api/auth/register (role: committee-admin)
        API->>DB: User.create({ role: "committee-admin", orgId })
        DB-->>API: Committee member created
        API-->>P: Committee setup complete
    end

    rect rgb(220, 255, 220)
        Note over S,C: Phase 2 — Grievance Management
        S->>API: POST /api/complaints (title, description, category)
        API->>API: generateUniqueTrackingId()
        API->>DB: Complaint.create({ trackingId, ...NO userId })
        API->>DB: ComplaintTracking.create({ trackingId, encryptedUserId })
        API-->>S: { trackingId: "VSF-2024-XXXX" }

        C->>API: GET /api/complaints
        API->>DB: Complaint.find({ orgId }) -- no userId exposed
        DB-->>API: Complaint list (anonymous)
        API-->>C: Complaint dashboard data

        C->>API: POST /api/chat/start (trackingId)
        API-->>S: Socket event: "chat-invite"
        S->>API: Socket join room (trackingId)
        C->>API: Socket message
        API-->>S: Real-time anonymous message

        C->>API: PUT /api/complaints/:id/status { status: "resolved" }
        API->>DB: complaint.updateStatus("resolved")
        API-->>C: Status updated

        S->>API: GET /api/complaints/track/:trackingId
        API-->>S: { status: "resolved" }
    end

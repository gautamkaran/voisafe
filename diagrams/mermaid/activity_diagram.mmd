flowchart TD
    A([Start]) --> B[Principal Registers Institution]
    B --> C{Super Admin Reviews}
    C -- Rejected --> D[Notify Principal - Resubmit]
    D --> B
    C -- Approved --> E[Set isVerified = true]
    E --> F[Principal Creates Committee Members]
    F --> G[Students Register under Institution]
    G --> H[Student Submits Anonymous Complaint]
    H --> I[System Generates Tracking ID]
    I --> J[Store Complaint WITHOUT userId]
    J --> K[Store Encrypted Identity in ComplaintTracking]
    K --> L[Return Tracking ID to Student]
    L --> M[Committee Admin Views Complaint Dashboard]
    M --> N{Complaint Review}
    N -- Needs Info --> O[Initiate Live Chat via Tracking ID]
    O --> P[Student Joins Chat Anonymously]
    P --> Q[Chat Session Active]
    Q --> R{Resolution Reached?}
    R -- No --> Q
    R -- Yes --> S[Admin Updates Status to Resolved]
    N -- Direct Resolution --> S
    S --> T[Student Checks Status via Tracking ID]
    T --> U([End])

graph TB
    subgraph ClientTier["Client Tier (Browser)"]
        WebApp["Next.js Web App"]
        StudentUI["Student Portal"]
        AdminUI["Admin Dashboard"]
        SuperAdminUI["Super Admin Dashboard"]
    end

    subgraph AppTier["Application Tier (Express API)"]
        AuthCtrl["Auth Controller"]
        ComplaintCtrl["Complaint Controller"]
        ChatCtrl["Chat Controller"]
        InstitutionCtrl["Institution Controller"]
        AnonEngine["Anonymization Engine"]
        SocketIO["Socket.IO Server"]
        JWTMiddleware["JWT Auth Middleware"]
        RBACMiddleware["RBAC Middleware"]
    end

    subgraph DataTier["Data Tier (MongoDB Atlas)"]
        OrgCollection[("Organizations")]
        UserCollection[("Users")]
        ComplaintCollection[("Complaints")]
        TrackingCollection[("ComplaintTracking")]
        ChatCollection[("ChatMessages")]
    end

    WebApp --> StudentUI
    WebApp --> AdminUI
    WebApp --> SuperAdminUI

    StudentUI -->|"HTTPS + WSS"| JWTMiddleware
    AdminUI -->|"HTTPS + WSS"| JWTMiddleware
    SuperAdminUI -->|"HTTPS"| JWTMiddleware

    JWTMiddleware --> RBACMiddleware
    RBACMiddleware --> AuthCtrl
    RBACMiddleware --> ComplaintCtrl
    RBACMiddleware --> ChatCtrl
    RBACMiddleware --> InstitutionCtrl

    ComplaintCtrl --> AnonEngine
    AnonEngine -->|"No userId"| ComplaintCollection
    AnonEngine -->|"Encrypted map"| TrackingCollection

    ChatCtrl --> SocketIO
    SocketIO -->|"Room: trackingId"| ChatCollection

    AuthCtrl --> UserCollection
    AuthCtrl --> OrgCollection
    InstitutionCtrl --> OrgCollection

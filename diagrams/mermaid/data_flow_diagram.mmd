flowchart TD
    subgraph External["External Entities"]
        SA(["👑 Super Admin"])
        P(["🏫 Principal"])
        S(["🎓 Student"])
        C(["👥 Committee Admin"])
    end

    subgraph Process["Data Processes"]
        P1["1.0 Authenticate & Register"]
        P2["2.0 Approve Institution"]
        P3["3.0 File Anonymous Complaint"]
        P4["4.0 Manage Complaints"]
        P5["5.0 Live Anonymous Chat"]
    end

    subgraph DataStore["Data Stores"]
        DS1[("D1: Organizations")]
        DS2[("D2: Users")]
        DS3[("D3: Complaints")]
        DS4[("D4: ComplaintTracking")]
        DS5[("D5: ChatMessages")]
    end

    SA -->|"Review request"| P2
    P -->|"Register Institution"| P1
    S -->|"Register as Student"| P1
    C -->|"Login credentials"| P1

    P1 --> DS1
    P1 --> DS2

    P2 -->|"isVerified = true"| DS1

    S -->|"title, description, category"| P3
    P3 -->|"Store complaint (no userId)"| DS3
    P3 -->|"Store encrypted identity"| DS4
    P3 -->|"Tracking ID"| S

    C -->|"View complaints"| P4
    P4 <--> DS3
    P4 -->|"Status update"| DS3
    S -->|"trackingId"| P4
    P4 -->|"Status info"| S

    C -->|"Start chat (trackingId)"| P5
    S -->|"Join chat (trackingId)"| P5
    P5 <--> DS5
